<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- MVP dev tool: sandbox disabled so the app can spawn the Python helper
         and read user-selected folders. Re-enable before distribution. -->
    <key>com.apple.security.app-sandbox</key>
    <false/>
</dict>
</plist>
