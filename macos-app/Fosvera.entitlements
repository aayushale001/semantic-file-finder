<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Developer ID / GitHub releases can be notarized without the Mac App
         Store sandbox. Keep this disabled until the app is redesigned around
         security-scoped bookmarks for a future App Store build. -->
    <key>com.apple.security.app-sandbox</key>
    <false/>
</dict>
</plist>
