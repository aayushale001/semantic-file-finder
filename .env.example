# Copy this file to ".env" and fill in your key. Never commit the real .env.

# --- Required ----------------------------------------------------------------
GEMINI_API_KEY=your_api_key_here

# --- App data ----------------------------------------------------------------
# Stable legacy path retained so existing Fosvera testers keep their index.
APP_DATA_DIR=~/.semantic_file_finder

# --- Embedding model ---------------------------------------------------------
# Multimodal-ready default. This is the intended model as the app grows to
# support images/audio/video/documents/code.
GEMINI_EMBEDDING_MODEL=gemini-embedding-2
GEMINI_EMBEDDING_DIMENSIONS=768

# Text-only fallback:
#   The ONLY way to use gemini-embedding-001 is to set BOTH of these:
#     GEMINI_EMBEDDING_MODEL=gemini-embedding-001
#     TEXT_ONLY_MODE=true
#   gemini-embedding-v1 is never allowed.
TEXT_ONLY_MODE=false

# --- Optional tuning ---------------------------------------------------------
# GEMINI_EMBEDDING_BATCH_SIZE=32
# CHUNK_SIZE=1200
# CHUNK_OVERLAP=200
# CODE_CHUNK_LINES=120
# LOG_LEVEL=INFO
